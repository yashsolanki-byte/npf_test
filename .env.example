# Copy to ".env" and fill in (never commit .env).
# Passwords for NPF publisher logins — used by manual scrape, batch scrape, and script_scraper.

NPF_PASSWORD_CENTRAL=
NPF_PASSWORD_SANJAY=
NPF_PASSWORD_AMIT=

# Optional: ms to wait after Campaign Detailed View loads so institute dropdown can populate (default 2500).
# NPF_DETAILED_VIEW_SETTLE_MS=3500

# Manual scrape (web app): max "Primary Leads" count before aborting and asking for a smaller date range (default 100000). Set to 0 to disable.
# NPF_MANUAL_SCRAPE_MAX_LEADS=100000
